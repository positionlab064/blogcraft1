# OPENAI_API_KEY: Required for OpenAI API calls (GPT-4o-mini).
OPENAI_API_KEY="MY_OPENAI_API_KEY"

# APP_URL: 프론트엔드 URL (CORS 허용 출처) - 프로덕션에서 반드시 설정
# 예: https://your-app.pages.dev 또는 https://your-frontend.vercel.app
APP_URL="MY_APP_URL"

# PORT: Backend server port (default: 3001)
PORT=3001

# NODE_ENV: "development" or "production"
NODE_ENV=development

# JWT_SECRET: JWT 서명 비밀키 - 프로덕션에서 반드시 강력한 랜덤 문자열로 설정
# 생성 방법: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET="CHANGE_THIS_TO_A_STRONG_RANDOM_SECRET"

# DATABASE_PATH: SQLite DB 파일 경로
# - 로컬: 기본값 사용 (생략 가능, blogcraft.db를 현재 디렉토리에 생성)
# - Railway: Volume 마운트 경로 설정 (예: /data/blogcraft.db)
# DATABASE_PATH=/data/blogcraft.db

# VITE_API_URL: 프론트엔드에서 백엔드 API를 호출할 URL (프론트엔드 빌드 시 사용)
# 예: https://your-backend.up.railway.app
# VITE_API_URL=https://your-backend.up.railway.app
